# Fintrack backend environment template
# Note: the current codebase still uses hardcoded development settings in
# backend_project/settings.py. These variables define the environment contract
# we will wire into the settings split in the next foundation task.

DJANGO_SETTINGS_MODULE=backend_project.settings
DJANGO_SECRET_KEY=change-me-in-local-env
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOW_ALL_ORIGINS=True
DJANGO_TIME_ZONE=UTC
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3

# JWT defaults to mirror the current project settings
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=1
